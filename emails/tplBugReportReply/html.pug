doctype transitional
html
  head
    meta(charset='utf-8')
  body
    h2 #{t('Hi')} #{name},
    p
      | #{t('A reply has been published to the bug report you sent for the activity')} 
      strong #{activityName}
      | .
    
    div(style="background-color: #f7f9fa; border-left: 4px solid #007bff; padding: 15px; margin: 20px 0;")
      h4(style="margin-top: 0;") #{t('Reply:')}
      p(style="white-space: pre-wrap; font-size: 16px;") #{replyText}
    
    div(style="color: #6c757d; font-size: 14px; margin-top: 30px; border-top: 1px solid #dee2e6; padding-top: 15px;")
      h5 #{t('Details of your original report:')}
      p
        strong #{t('Activity:')}
        |  #{activityName}
      p
        strong #{t('Description:')}
      p(style="white-space: pre-wrap;") #{originalDescription}
